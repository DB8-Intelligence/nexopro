# ============================================
# NexoOmnix — Variáveis de Ambiente
# Copie para .env.local e preencha os valores
# NUNCA commite .env.local
# ============================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_anon_key_aqui
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key_aqui

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=NexoOmnix

# --- Anthropic (IA Contador - Camada 4) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Asaas (Cobranças - boleto, Pix, cartão) ---
ASAAS_API_KEY=sua_asaas_key_aqui
ASAAS_ENVIRONMENT=sandbox
# Em produção: ASAAS_ENVIRONMENT=production

# --- Focus NFe (Notas Fiscais NFS-e) ---
FOCUS_NFE_TOKEN=seu_token_focus_aqui
FOCUS_NFE_ENVIRONMENT=homologacao
# Em produção: FOCUS_NFE_ENVIRONMENT=producao

# --- WhatsApp (Evolution API ou Z-API) ---
WHATSAPP_API_URL=https://sua-instancia.evolution.com
WHATSAPP_API_KEY=sua_key_aqui
WHATSAPP_INSTANCE=nexoomnix

# --- Upload de Imagens (Supabase Storage) ---
NEXT_PUBLIC_SUPABASE_STORAGE_URL=https://SEU_PROJETO.supabase.co/storage/v1

# --- DB8-Agent (Railway — FFmpeg + Gemini Vision) ---
DB8_AGENT_URL=https://api.db8intelligence.com.br

# --- n8n Webhook Token (Railway — callbacks de vídeo) ---
N8N_WEBHOOK_TOKEN=seu_token_secreto_aqui

# --- n8n Skill Factory Webhook (aciona geração de Skills sob demanda) ---
N8N_SKILL_FACTORY_WEBHOOK=https://automacao.db8intelligence.com.br/webhook/skill-factory-trigger

# --- n8n Reel Generation Webhook (autopilot de reels) ---
# Workflow n8n que recebe briefing {project_id, tenant_id, scenes[], caption,
# voice_script, duration_sec, branding, callback_url} e orquestra:
#   1. Pra cada cena: POST $NEXT_PUBLIC_APP_URL/api/reel-creator/generate-image
#   2. POST $NEXT_PUBLIC_APP_URL/api/reel-creator/generate-voice
#   3. FFmpeg assembly no Railway db8-agent (bucket 'content', path reels/<tenant>/...)
#   4. POST callback_url com {project_id, video_url, job_id}
# Callback Next.js: /api/webhooks/reel-generated (valida via N8N_WEBHOOK_TOKEN).
N8N_REEL_GENERATION_WEBHOOK=

# --- Vercel Cron (publisher de scheduled_posts a cada 5min) ---
# Configurar no Vercel dashboard. Valor arbitrário forte (openssl rand -hex 32).
CRON_SECRET=

# --- Canva Connect OAuth ---
# Criar app em https://www.canva.com/developers/apps e configurar redirect URI
# como $NEXT_PUBLIC_APP_URL/api/canva/callback.
# Scopes usados: design:meta:read, design:content:read, asset:read, profile:read
CANVA_CLIENT_ID=
CANVA_CLIENT_SECRET=

# --- Bug-catcher webhook (opcional) ---
# Slack incoming webhook ou endpoint genérico que aceita {text, bug}.
# Se setado, cada bug criado via /api/bugs dispara um POST pra esse URL.
BUG_WEBHOOK_URL=

# --- Sentry (opcional, integração externa) ---
# Se quiser captura automática de erros JS/React não reportados manualmente,
# instalar @sentry/nextjs e configurar estas vars.
# Doc: https://docs.sentry.io/platforms/javascript/guides/nextjs/
# SENTRY_DSN=
# SENTRY_AUTH_TOKEN=

# --- ContentAI — Fase 7 ---
FAL_KEY=                              # Fal.ai para geração de imagens (Flux)
ELEVENLABS_API_KEY=                   # ElevenLabs para síntese de voz

# --- Meta API (Instagram + Facebook Auto-post — PRO MAX) ---
META_APP_ID=                          # Facebook App ID (developers.facebook.com)
META_APP_SECRET=                      # Facebook App Secret
# Configurar em: Facebook Developer Console > App > Facebook Login > Valid OAuth redirect URIs
# Adicionar: https://nexoomnix.com/api/meta/callback
# Permissões necessárias: pages_show_list, pages_read_engagement, pages_manage_posts,
#   instagram_basic, instagram_content_publish, instagram_manage_comments
# Preço PRO MAX: R$ 499/mês (inclui auto-post + Instagram Viral Engine)

# --- Stripe (Monetização — Fase 8) ---
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_PRO_PLUS=price_...
STRIPE_PRICE_PRO_MAX=price_...
STRIPE_PRICE_ENTERPRISE=price_...
# Add-on: Objetos Falantes IA (R$49/mês — disponível em qualquer plano)
STRIPE_PRICE_ADDON_TALKING_OBJECTS=price_...

# --- Resend (E-mail — Fase 8) ---
RESEND_API_KEY=re_...
RESEND_FROM=NexoOmnix <noreply@nexoomnix.com>

# --- Vercel Analytics (Fase 10) ---
# Ativado automaticamente pelo Vercel — sem variáveis extras necessárias

# --- Domínios (Vercel — Fase 10) ---
# nexoomnix.com     → domínio principal (todos os nichos)
# nexopro.app       → alias legacy
# imobpro.app       → nicho imoveis
# salaopro.app      → nicho beleza
# reelcreator.app   → nicho fotografia (Omnix Reels)
